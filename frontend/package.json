{
  "name": "pnku-website-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && cross-env VITE_REMOTE_COMPONENT_DEV_MODE=false vite build",
    "build:analyze": "tsc -b && cross-env ANALYZE_BUNDLE=true vite build",
    "build:remote": "tsc -b && vite build --config vite.config.remote.ts",
    "build:remote:analyze": "tsc -b && cross-env ANALYZE_BUNDLE=true vite build --config vite.config.remote.ts",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "prettier:fix": "prettier --write .",
    "prettier:check": "prettier --check .",
    "check": "pnpm lint && pnpm prettier:check && pnpm build",
    "clean": "rimraf build"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "dependencies": {
    "@ant-design/colors": "^8.0.0",
    "@ant-design/cssinjs": "^1.24.0",
    "@ant-design/icons": "^5.6.1",
    "@ant-design/plots": "^2.6.5",
    "@tailwindcss/vite": "^4.2.1",
    "antd": "^5.27.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "colorjs.io": "^0.5.2",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.18",
    "fast-diff": "^1.3.0",
    "html-react-parser": "^5.2.6",
    "pako": "^2.1.0",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-copy-to-clipboard": "^5.1.0",
    "react-dom": "^18.3.1",
    "react-google-recaptcha": "^3.1.0",
    "react-h5-audio-player": "^3.10.1",
    "react-icons": "^5.5.0",
    "react-router": "^7.9.4",
    "react-timeago": "^8.3.0",
    "react-use-error-boundary": "^3.0.0",
    "seedrandom": "^3.0.5",
    "swr": "^2.3.6",
    "tailwind-merge": "^3.3.1",
    "textarea-caret": "^3.1.0",
    "y-protocols": "^1.0.6",
    "y-utility": "^0.1.4",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.27"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^22.18.6",
    "@types/pako": "^2.0.4",
    "@types/react": "^18.3.24",
    "@types/react-copy-to-clipboard": "^5.0.7",
    "@types/react-dom": "^18.3.7",
    "@types/react-google-recaptcha": "^2.1.9",
    "@types/react-timeago": "^4.1.7",
    "@types/seedrandom": "^3.0.8",
    "@types/textarea-caret": "^3.0.4",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "@vitejs/plugin-react": "^5.0.3",
    "cross-env": "^10.0.0",
    "daisyui": "^5.2.3",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.4.0",
    "javascript-obfuscator": "^4.1.1",
    "magic-string": "^0.30.21",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "rimraf": "^6.0.1",
    "rollup-plugin-obfuscator": "^1.1.0",
    "tailwindcss": "^4.1.14",
    "terser": "^5.44.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.2",
    "vite": "^7.2.2",
    "vite-bundle-analyzer": "^1.2.3",
    "vite-plugin-compression2": "^2.2.1",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-svgr": "^4.5.0"
  }
}
